{
  "$schema": "../_schema/charte.schema.json",
  "name": "credit-agricole",
  "label": "Crédit Agricole",
  "source": "credit-agricole.com (CSS app-main + app-articles, extraction 2026-05-13)",
  "notes": "Charte corporate du groupe — communication institutionnelle. Variante 'La Fabrique by CA' à dériver dans une charte enfant si besoin (logo + accents).",

  "colors": {
    "primary":         { "value": "#008991", "name": "Sarcelle CA",        "usage": "couleur corporate dominante, headers, accents principaux" },
    "primary-dark":    { "value": "#007178", "name": "Sarcelle foncé",     "usage": "hover, contraste sur fonds clairs" },
    "primary-deep":    { "value": "#005860", "name": "Sarcelle profond",   "usage": "fonds sombres, dividers de section" },

    "signature":       { "value": "#82B600", "name": "Vert pomme",         "usage": "couleur signature CA, CTAs, highlights, accents joyeux" },
    "signature-dark":  { "value": "#75A300", "name": "Vert olive",         "usage": "hover de signature" },
    "signature-deep":  { "value": "#3D6D04", "name": "Vert forêt",         "usage": "texte sur fond clair, deep accent" },

    "accent-mint":     { "value": "#49CEAA", "name": "Menthe",             "usage": "accents modernes, mise en avant douce" },

    "alert":           { "value": "#FF3521", "name": "Rouge alerte",       "usage": "erreurs, alertes" },
    "warning":         { "value": "#8A6D3B", "name": "Ambre",              "usage": "avertissements" },
    "info":            { "value": "#337AB7", "name": "Bleu info",          "usage": "infos neutres" },

    "text":            { "value": "#2E3738", "name": "Anthracite",         "usage": "corps de texte principal" },
    "text-strong":     { "value": "#000000", "name": "Noir",               "usage": "titres très contrastés" },
    "text-soft":       { "value": "#404040", "name": "Gris foncé",         "usage": "sous-titres, légendes" },
    "muted":           { "value": "#676767", "name": "Gris moyen",         "usage": "texte secondaire, méta-info" },
    "muted-soft":      { "value": "#A6A6A6", "name": "Gris doux",          "usage": "labels désactivés, dividers verbaux" },

    "rule":            { "value": "#D9D9D9", "name": "Trait standard",     "usage": "filets, bordures" },
    "rule-soft":       { "value": "#E0E0E0", "name": "Trait léger",        "usage": "séparateurs discrets" },

    "bg":              { "value": "#FFFFFF", "name": "Blanc",              "usage": "fond principal" },
    "bg-soft":         { "value": "#F5F5F5", "name": "Gris clair",         "usage": "fond alternatif, hover lignes" },
    "bg-canvas":       { "value": "#EBEBEB", "name": "Canvas",             "usage": "fond de page institutionnel" },

    "panel-mint":      { "value": "#E8F4EF", "name": "Panel menthe",       "usage": "panneaux 'recommandations', encarts doux (dérivé du menthe)" },
    "panel-teal":      { "value": "#E6F1F2", "name": "Panel sarcelle",     "usage": "panneaux d'info, encarts corporate" },
    "panel-cream":     { "value": "#F8F5EE", "name": "Crème",              "usage": "fond chaud pour highlights (non officiel, à valider)"  }
  },

  "fonts": {
    "primary": {
      "family": "Raleway",
      "fallback": ["Inter", "Helvetica Neue", "Helvetica", "Arial", "sans-serif"],
      "weights": [300, 400, 500, 600, 700, 800],
      "source": "Google Fonts — https://fonts.google.com/specimen/Raleway",
      "local_files": ["assets/fonts/Raleway[wght].ttf", "assets/fonts/Raleway-Italic[wght].ttf"],
      "usage": "corps de texte, titres, UI — police officielle des decks CA"
    }
  },

  "type-scale": {
    "h1": { "size_pt": 46, "weight": 800, "line_height": 1.0,  "letter_spacing": "-0.01em" },
    "h2": { "size_pt": 30, "weight": 800, "line_height": 1.05, "letter_spacing": "-0.005em" },
    "h3": { "size_pt": 22, "weight": 800, "line_height": 1.1,  "letter_spacing": "0" },
    "lead":     { "size_pt": 13, "weight": 400, "line_height": 1.5 },
    "body":     { "size_pt": 10.5, "weight": 400, "line_height": 1.45 },
    "small":    { "size_pt": 9, "weight": 400, "line_height": 1.4 },
    "eyebrow":  { "size_pt": 9, "weight": 700, "letter_spacing": "0.14em", "transform": "uppercase" },
    "label":    { "size_pt": 8.5, "weight": 800, "letter_spacing": "0.12em", "transform": "uppercase" }
  },

  "radii": {
    "sm": 2,
    "md": 4,
    "lg": 8
  },

  "spacing": {
    "page_margin_mm": 9,
    "gutter_mm": 6
  },

  "defaults": {
    "_description": "Assets injectés automatiquement par les layouts quand l'appelant ne les fournit pas. Path relatifs à chartes/<nom>/assets/.",
    "cover_photo":   "photo/ca-siege.jpg",
    "cover_logo":    "logo/ca-logo-baseline.png",
    "header_logo":   "logo/ca-ina-logo.png"
  },

  "logo": {
    "files": {
      "primary_svg":      "assets/logo/credit-agricole-primary.svg",
      "primary_png":      "assets/logo/credit-agricole-primary.png",
      "monochrome_white": "assets/logo/credit-agricole-white.svg"
    },
    "clear_space_mm": 6,
    "min_width_mm": 18,
    "notes": "Logos à fournir par l'utilisateur — placeholders pour l'instant. Le logo officiel est l'éléphant/carré au texte 'CRÉDIT AGRICOLE' sur fond sarcelle ou blanc."
  },

  "iconography": {
    "style": "linear, stroke 1.5px, coins arrondis",
    "stroke_color": "primary"
  }
}
