{
  "name": "blank",
  "label": "Blank — generic placeholder",
  "source": "Neutral palette + Inter. Use as a starting point for a new client charte.",
  "notes": "Copy this folder to start a new theme : cp -r chartes/blank chartes/<client>. Then edit tokens.json + drop the client's logos/fonts under assets/.",

  "colors": {
    "primary":         { "value": "#2563EB", "name": "Royal blue",   "usage": "couleur dominante, headers, labels" },
    "primary-dark":    { "value": "#1D4ED8", "name": "Royal foncé",  "usage": "hover, contraste" },
    "primary-deep":    { "value": "#1E3A8A", "name": "Royal profond","usage": "fonds sombres, dividers" },

    "signature":       { "value": "#F59E0B", "name": "Amber",        "usage": "accents, CTAs, highlights" },
    "signature-dark":  { "value": "#D97706", "name": "Amber dark",   "usage": "hover signature" },
    "signature-deep":  { "value": "#92400E", "name": "Amber deep",   "usage": "texte signature sur clair" },

    "accent-mint":     { "value": "#10B981", "name": "Emerald",      "usage": "accent doux, succès" },

    "alert":           { "value": "#EF4444", "name": "Rouge alerte", "usage": "erreurs" },
    "warning":         { "value": "#F59E0B", "name": "Ambre",        "usage": "avertissements" },
    "info":            { "value": "#3B82F6", "name": "Bleu info",    "usage": "infos" },

    "text":            { "value": "#1F2937", "name": "Anthracite",   "usage": "corps de texte" },
    "text-strong":     { "value": "#000000", "name": "Noir",         "usage": "titres" },
    "text-soft":       { "value": "#374151", "name": "Gris foncé",   "usage": "légendes" },
    "muted":           { "value": "#6B7280", "name": "Gris moyen",   "usage": "méta" },
    "muted-soft":      { "value": "#9CA3AF", "name": "Gris doux",    "usage": "désactivé" },

    "rule":            { "value": "#D1D5DB", "name": "Trait",        "usage": "filets" },
    "rule-soft":       { "value": "#E5E7EB", "name": "Trait léger",  "usage": "séparateurs discrets" },

    "bg":              { "value": "#FFFFFF", "name": "Blanc",        "usage": "fond principal" },
    "bg-soft":         { "value": "#F9FAFB", "name": "Gris clair",   "usage": "fond alternatif" },
    "bg-canvas":       { "value": "#F3F4F6", "name": "Canvas",       "usage": "fond institutionnel" },

    "panel-mint":      { "value": "#ECFDF5", "name": "Panel emerald","usage": "panneaux d'encart" },
    "panel-teal":      { "value": "#EFF6FF", "name": "Panel blue",   "usage": "panneaux info" },
    "panel-cream":     { "value": "#FFFBEB", "name": "Panel amber",  "usage": "panneaux highlights" }
  },

  "fonts": {
    "primary": {
      "family": "Inter",
      "fallback": ["Helvetica Neue", "Helvetica", "Arial", "sans-serif"],
      "weights": [400, 500, 600, 700, 800],
      "source": "Google Fonts — https://fonts.google.com/specimen/Inter",
      "usage": "tout — système type Inter par défaut, dispo partout"
    }
  },

  "type-scale": {
    "h1":     { "size_pt": 46, "weight": 800, "line_height": 1.0,  "letter_spacing": "-0.01em" },
    "h2":     { "size_pt": 30, "weight": 800, "line_height": 1.05 },
    "h3":     { "size_pt": 22, "weight": 800, "line_height": 1.1 },
    "lead":   { "size_pt": 13, "weight": 400, "line_height": 1.5 },
    "body":   { "size_pt": 10.5, "weight": 400, "line_height": 1.45 },
    "small":  { "size_pt": 9,    "weight": 400, "line_height": 1.4 },
    "eyebrow":{ "size_pt": 9, "weight": 700, "letter_spacing": "0.14em", "transform": "uppercase" },
    "label":  { "size_pt": 8.5, "weight": 800, "letter_spacing": "0.12em", "transform": "uppercase" }
  },

  "radii":   { "sm": 2, "md": 4, "lg": 8 },
  "spacing": { "page_margin_mm": 9, "gutter_mm": 6 },

  "defaults": {
    "_description": "No default assets shipped — drop logos/photos under assets/ then point here.",
    "cover_photo":  null,
    "cover_logo":   null,
    "header_logo":  null
  }
}
