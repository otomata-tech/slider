#!/usr/bin/env python3
"""Ingère un template PPTX client EN ENTIER comme thème slider.

Contrairement à `extract-charte` (qui ne relève que couleurs/polices), `ingest`
PRÉSERVE le template : master + slideLayouts conservés tels quels, catalogue des
layouts (placeholders + rôle déduit + signature), tokens dérivés du thème, et
photos harvestées. C'est ce thème qui permet de refaire un deck fidèle au client.

Usage :
    slide-craft ingest <template.pptx> --name=<theme> [--out=<dir>]

Défaut --out : ~/.local/share/slider/chartes (dossier thèmes stable).
"""
from __future__ import annotations

import argparse
import os
from pathlib import Path

from _common import PROJECT, fail, ok

import sys
sys.path.insert(0, str(PROJECT))
from lib.template import ingest          # noqa: E402
from lib.charte import _user_chartes     # noqa: E402  (même dossier que la résolution moteur)

DEFAULT_OUT = str(_user_chartes())


def main():
    ap = argparse.ArgumentParser(prog="slide-craft ingest")
    ap.add_argument("source", help="template PPTX client")
    ap.add_argument("--name", required=True, help="nom du thème")
    ap.add_argument("--out", default=DEFAULT_OUT, help=f"dossier thèmes (défaut {DEFAULT_OUT})")
    args = ap.parse_args()

    if not Path(args.source).exists():
        fail(f"introuvable : {args.source}")

    res = ingest(args.source, args.name, args.out)

    ok(f"✓ Thème ingéré : {res['theme']}")
    ok(f"  • template.pptx  préservé")
    ok(f"  • tokens.json    police « {res['family']} » + {res['palette']} couleurs de thème")
    ok(f"  • assets/photo/  {res['photos']} photos harvestées")
    if res["mode"] == "layouts":
        ok(f"  • mode MASQUES   {res['layouts']} layouts catalogués (placeholders + rôles)")
        ok(f"  → compose : slide-craft catalog {args.name} ; puis NativeDeck (remplir par rôle).")
    else:
        ok(f"  • mode MODÈLES   {res['models']} slides-modèles (pas de bibliothèque de masques)")
        ok(f"  → compose : slide-craft catalog {args.name} ; puis ModelDeck (cloner + réécrire par ancre).")


if __name__ == "__main__":
    main()
