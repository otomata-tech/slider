#!/usr/bin/env python3
"""Extract text + images from a .pptx into a workable folder.

Usage:
    slide-craft extract-pptx <source.pptx> <dest-dir>

Produces:
    <dest-dir>/
      source.pptx                  # copy of the original
      slides.txt                   # text per slide
      media/                       # all embedded images, original names
      slides/                      # per-slide xml (debugging)
"""
from __future__ import annotations

import argparse
import re
import shutil
import sys
import zipfile
from pathlib import Path

from _common import fail


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("source", type=Path, help=".pptx to extract")
    ap.add_argument("dest",   type=Path, help="destination directory")
    args = ap.parse_args()

    src: Path = args.source.expanduser().resolve()
    dst: Path = args.dest.expanduser().resolve()

    if not src.exists() or src.suffix.lower() != ".pptx":
        fail(f"not a .pptx file: {src}")
    dst.mkdir(parents=True, exist_ok=True)

    # 1. copy original
    shutil.copy2(src, dst / "source.pptx")

    # 2. extract zip
    media_dir = dst / "media";  media_dir.mkdir(exist_ok=True)
    slides_dir = dst / "slides"; slides_dir.mkdir(exist_ok=True)

    with zipfile.ZipFile(src) as z:
        for info in z.infolist():
            name = info.filename
            if name.startswith("ppt/media/"):
                with z.open(info) as f, open(media_dir / Path(name).name, "wb") as out:
                    shutil.copyfileobj(f, out)
            elif name.startswith("ppt/slides/") and name.endswith(".xml"):
                stem = Path(name).stem  # slide1, slide2, ...
                xml = z.read(info).decode("utf-8", errors="replace")
                (slides_dir / f"{stem}.xml").write_text(xml, encoding="utf-8")

    # 3. extract text per slide
    slides_txt_lines = []
    xml_files = sorted(slides_dir.glob("slide*.xml"),
                       key=lambda p: int(re.search(r"\d+", p.stem).group()))
    for sx in xml_files:
        n = int(re.search(r"\d+", sx.stem).group())
        xml = sx.read_text(encoding="utf-8")
        texts = re.findall(r"<a:t[^>]*>([^<]*)</a:t>", xml)
        text = "\n".join(t.strip() for t in texts if t.strip())
        slides_txt_lines.append(f"=== slide {n} ===\n{text}\n")
    (dst / "slides.txt").write_text("\n".join(slides_txt_lines), encoding="utf-8")

    # 4. report
    n_slides = len(xml_files)
    n_media  = len(list(media_dir.iterdir()))
    print(f"Extracted to {dst}")
    print(f"  · {n_slides} slides   → slides/*.xml + slides.txt")
    print(f"  · {n_media} media    → media/")
    print(f"  · original kept as source.pptx")


if __name__ == "__main__":
    main()
