#!/usr/bin/env python3
"""List brand chartes findable via SLIDER_THEMES_PATH + built-ins."""
import json
import os
import sys

from _common import PROJECT


def main():
    sys.path.insert(0, str(PROJECT))
    from lib.charte import Charte, _theme_search_paths

    chartes = Charte.discover()
    if not chartes:
        print("No charte found.")
        print()
        print("Searched paths:")
        for p in _theme_search_paths():
            mark = "✓" if p.exists() else "✗"
            print(f"  {mark} {p}")
        print()
        print("Tip: export SLIDER_THEMES_PATH=<path-to-your-theme-repo>/chartes")
        sys.exit(1)

    print("Available chartes (marques) :")
    print()
    for name, root in chartes:
        tokens = json.loads((root / "tokens.json").read_text())
        primary = tokens.get("colors", {}).get("primary", {}).get("value", "—")
        font    = tokens.get("fonts", {}).get("primary", {}).get("family", "—")
        label   = tokens.get("label", name)
        print(f"  • {name}")
        print(f"      label   : {label}")
        print(f"      primary : #{primary.lstrip('#')}")
        print(f"      font    : {font}")
        print(f"      path    : {root}")
        print()


if __name__ == "__main__":
    main()
