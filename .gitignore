__pycache__/
*.pyc
.venv/
node_modules/

# Client themes are cloned into chartes/<client>/ as separate repos.
# Only the built-in `blank` placeholder is tracked.
chartes/*
!chartes/blank/

# Generated outputs are regenerable via `slide-craft build <deck>`
decks/*/out/

# Smoke-test and scratch decks (use prefix `test-` to opt into gitignore)
decks/test-*/

# Local previews
preview-*.png
*-screen.png

# Large source files (originals from clients)
decks/*/source/*.pptx.bak
decks/*/source/*.docx.bak

# OS
.DS_Store

# User decks live in the user workspace, not the engine repo
decks/*
!decks/.gitkeep
